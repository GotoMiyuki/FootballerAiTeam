# ===========================================
# FootballAI Career Agent - 环境变量配置
# ===========================================

# --- 大模型 API 配置 ---
OPENAI_API_KEY=your-api
OPENAI_BASE_URL=your-url
MODEL_NAME=your-model

# --- Tavily 搜索 API ---
TAVILY_API_KEY=your-api

# --- 应用配置 ---
# 最大对话轮数
MAX_CONVERSATION_TURNS=10
# 短期记忆窗口大小
SHORT_MEMORY_SIZE=5
# 调试模式
DEBUG=true